{
  "name": "website",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:network": "nuxt dev --host 0.0.0.0 --port 3000",
    "dev:mobile": "NUXT_DEVTOOLS=false nuxt dev --host 0.0.0.0 --port 3000",
    "generate": "nuxt generate",
    "deploy": "nuxt generate && npx wrangler pages deploy dist/",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:fast": "oxlint .",
    "lint:fast:fix": "oxlint . --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "dependencies": {
    "@hypernym/nuxt-anime": "2.1.1",
    "@iconify-json/mynaui": "^1.2.17",
    "@iconify-json/ph": "^1.2.2",
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/icon": "2.2.1",
    "@nuxt/image": "2.0.0",
    "@nuxtjs/color-mode": "4.0.0",
    "@nuxtjs/device": "4.0.0",
    "@nuxtjs/i18n": "10.2.3",
    "@nuxtjs/seo": "3.4.0",
    "@unocss/nuxt": "66.6.6",
    "@vue-gsap-flip/nuxt": "1.1.1",
    "@vueuse/nuxt": "14.2.1",
    "@vueuse/sound": "^2.1.3",
    "nuxt": "^4.4.2",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4",
    "web-haptics": "^0.0.6"
  },
  "devDependencies": {
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "unocss": "^66.6.7"
  }
}